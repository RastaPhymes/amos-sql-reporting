	SELECT
	    q.mpno,
	    q.issue_no,
	    q.mp_revision_no,
	    q.section_code,
		q.reference_link_main,
	    q.taskcardno,
	    CASE q.single_running
    		WHEN 'B' THEN 'Block Taskcard'
    		WHEN 'C' THEN 'Check Controlled'
    		WHEN 'D' THEN 'Document Controlled'
    		WHEN 'O' THEN 'On Demand'
    		WHEN 'R' THEN 'Rotable Controlled'
    		WHEN 'S' THEN 'Single Running'
    		WHEN 'T' THEN 'Taskcard Controlled'
    		ELSE q.single_running
		END AS single_running,
		q.task_type_code,
		q.msg_code,
		q.taskcard_zone,
		q.customized_zone,
		q.zone,
	    q.task_special_code,
		q.special,
		(
    		SELECT STRING_AGG(DISTINCT TRIM(val), '; ' ORDER BY TRIM(val))
    		FROM UNNEST(
        		STRING_TO_ARRAY(
		            CONCAT_WS(';',
        		        COALESCE(q.task_special_code, ''),
                		COALESCE(q.special, '')
            		),
            		';'
        		)
    		) AS t(val)
    		WHERE TRIM(val) <> ''
		) AS combined_special,
	    q.taskcardno_i,
	    q.taskcard_verno_i,
	    q.title,
	    q.descno_i,
	    q.workstep_text,
		q.eff_notes,
	    q.revision_date,
	    q.revision_no,
	    q.release_date,
	    q.revision_reason,
	    q.mrb_revision_number,
	    q.mrb_revision_date,
	    q.mrb_revision_reason,
	    q.itemno_i,
	    q.event_key,
	    q.effectivityno_i,
	    q.higher_effectivityno_i,
	    q.parent_effectivityno_i,
	    q.effectivity_linkno_i,
	    q.effectivity_status,
	
	    CASE
	        WHEN e1.effectivityno_i IS NULL THEN 0
	        WHEN e2.effectivityno_i IS NULL THEN 1
	        WHEN e3.effectivityno_i IS NULL THEN 2
	        WHEN e4.effectivityno_i IS NULL THEN 3
	        WHEN e5.effectivityno_i IS NULL THEN 4
	        WHEN e6.effectivityno_i IS NULL THEN 5
	        WHEN e7.effectivityno_i IS NULL THEN 6
	        WHEN e8.effectivityno_i IS NULL THEN 7
	        WHEN e9.effectivityno_i IS NULL THEN 8
	        WHEN e10.effectivityno_i IS NULL THEN 9
	        WHEN e11.effectivityno_i IS NULL THEN 10
	        WHEN e12.effectivityno_i IS NULL THEN 11
	        WHEN e13.effectivityno_i IS NULL THEN 12
	        WHEN e14.effectivityno_i IS NULL THEN 13
	        WHEN e15.effectivityno_i IS NULL THEN 14
	        WHEN e16.effectivityno_i IS NULL THEN 15
	        WHEN e17.effectivityno_i IS NULL THEN 16
	        WHEN e18.effectivityno_i IS NULL THEN 17
	        WHEN e19.effectivityno_i IS NULL THEN 18
	        WHEN e20.effectivityno_i IS NULL THEN 19
	        ELSE 20
	    END AS EFF_DEPTH,
	
	    CASE
	        WHEN q.parent_effectivityno_i IS NOT NULL THEN 'CHILD'
	        ELSE 'ROOT'
	    END AS effectivity_type,
	
	    q.effectivity_title,
	    q.aircraft_mission_config,
	    q.aircraft_operator,
		q.applicability,
	    q.dimension_group_name,
	    q.is_customized_effectivity,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_INTERVALNO_I
	        ELSE q.REQH_INTERVALNO_I
	    END AS intervalno_i,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_BASED_ON
	        ELSE q.REQH_BASED_ON
	    END AS based_on,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_DOC_TYPE
	        ELSE q.REQH_DOC_TYPE
	    END AS doc_type,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_DOCNO
	        ELSE q.REQH_DOCNO
	    END AS docno,

		CASE
    WHEN (
        CASE
            WHEN q.is_customized_effectivity = 'YES'
            THEN q.EFL_NEXT_DUE_RULE_ID
            ELSE q.REQH_NEXT_DUE_RULE_ID
        END
    ) = 0
    THEN q.PREDEFINED_MODEL
    ELSE
        CASE
            WHEN q.is_customized_effectivity = 'YES'
            THEN q.EFL_NEXT_DUE_RULE_ID
            ELSE q.REQH_NEXT_DUE_RULE_ID
        END
END AS effective_next_due_rule_id,

CASE
    WHEN (
        CASE
            WHEN (
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
            ) = 0
            THEN q.PREDEFINED_MODEL
            ELSE
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
        END
    ) = -1 THEN 'Standard'
    WHEN (
        CASE
            WHEN (
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
            ) = 0
            THEN q.PREDEFINED_MODEL
            ELSE
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
        END
    ) = 1 THEN 'Groundtime Extension'
    WHEN (
        CASE
            WHEN (
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
            ) = 0
            THEN q.PREDEFINED_MODEL
            ELSE
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
        END
    ) = 2 THEN 'Tolerance Extension'
    WHEN (
        CASE
            WHEN (
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
            ) = 0
            THEN q.PREDEFINED_MODEL
            ELSE
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
        END
    ) = 3 THEN 'Last Performed'
    WHEN (
        CASE
            WHEN (
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
            ) = 0
            THEN q.PREDEFINED_MODEL
            ELSE
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
        END
    ) = 4 THEN 'Groundtime + Tolerance Extension'
    WHEN (
        CASE
            WHEN (
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
            ) = 0
            THEN q.PREDEFINED_MODEL
            ELSE
                CASE
                    WHEN q.is_customized_effectivity = 'YES'
                    THEN q.EFL_NEXT_DUE_RULE_ID
                    ELSE q.REQH_NEXT_DUE_RULE_ID
                END
        END
    ) = 100 THEN 'Flexible'
    ELSE 'Unknown'
END AS next_due_rule,

CASE
    WHEN q.is_customized_effectivity = 'YES'
    THEN q.EFL_STATUS
    ELSE q.REQH_STATUS
END AS status,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_THR_CYC
	        ELSE q.REQH_THR_CYC
	    END AS THR_CYC,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_THR_HRS
	        ELSE q.REQH_THR_HRS
	    END AS THR_HRS,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_THR_DAY
	        ELSE q.REQH_THR_DAY
	    END AS THR_DAY,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_THR_UNIT
	        ELSE q.REQH_THR_UNIT
	    END AS THR_UNIT,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_INT_CYC
	        ELSE q.REQH_INT_CYC
	    END AS INT_CYC,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_INT_HRS
	        ELSE q.REQH_INT_HRS
	    END AS INT_HRS,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_INT_DAY
	        ELSE q.REQH_INT_DAY
	    END AS INT_DAY,
	
	    CASE
	        WHEN q.is_customized_effectivity = 'YES' THEN q.EFL_INT_UNIT
	        ELSE q.REQH_INT_UNIT
	    END AS INT_UNIT
	
	FROM (
	    SELECT
	        mmp.mpno,
	        mmi.issue_no,
	        mmr.revision_no AS mp_revision_no,
	        STRING_AGG(DISTINCT msc_sec.section_code, '; ') AS section_code,
			STRING_AGG(DISTINCT mtc.typecode, '; ') AS task_type_code,
			STRING_AGG(DISTINCT mmc.msgno, '; ') AS msg_code,
			STRING_AGG(DISTINCT mrz.zone, '; ') AS taskcard_zone,
			STRING_AGG(DISTINCT zcl_efl.zone, '; ') AS customized_zone,
			CASE
    			WHEN COUNT(DISTINCT zcl_efl.zone) > 0
    			THEN STRING_AGG(DISTINCT zcl_efl.zone, '; ')
    			ELSE STRING_AGG(DISTINCT mrz.zone, '; ')
			END AS zone,
			STRING_AGG(
    			DISTINCT CONCAT_WS(
        		' | ',
        		NULLIF(dbl_main.ref_type, ''),
        		NULLIF(dbl_main.description, ''),
        		NULLIF(dbl_main.link_remarks, '')
   			),
    		'; '
			) AS reference_link_main,
	        mt.taskcardno,
	        mtv.single_running,
	        STRING_AGG(DISTINCT mtsp.code, '; ') AS task_special_code,
	        mt.taskcardno_i,
	        mtv.taskcard_verno_i,
	        mt.title,
	        CASE
	    WHEN wsl_efl.descno_i IS NOT NULL THEN wsl_efl.descno_i
	    ELSE wsl_reqh.descno_i
	END AS descno_i,
	
	CASE
	    WHEN wsl_efl.descno_i IS NOT NULL THEN wtd_efl.text
	    ELSE wtd_reqh.text
	END AS workstep_text,
			mi.eff_notes,
	        mtv.revision_date,
	        mtv.revision_no,
	        mtv.release_date,
	        mtv.revision_reason,
	        mtv.mrb_revision_number,
	        mtv.mrb_revision_date,
	        mtv.mrb_revision_reason,
	        mi.itemno_i,
	        eel.event_key,
	        eel.effectivityno_i,
	        ee.higher_effectivityno_i,
	        ee.parent_effectivityno_i,
	        eel.effectivity_linkno_i,
	
	        CASE
	            WHEN ee.status = '0' THEN 'Active'
	            WHEN ee.status = '1' THEN 'Inactive'
	            ELSE 'Unknown'
	        END AS effectivity_status,
	
	        ee.title AS effectivity_title,
	        amc.code AS aircraft_mission_config,
	        adr.vendor AS aircraft_operator,
	        STRING_AGG(DISTINCT scl.special, '; ') AS special,

			STRING_AGG(
    			DISTINCT ac_appl.ac_registr,
    			'; '
    			ORDER BY ac_appl.ac_registr
			) AS applicability,
	
	        CASE
	            WHEN MAX(CASE WHEN ttr_efl.timerequirementno_i IS NOT NULL THEN 1 ELSE 0 END) = 1
	            THEN STRING_AGG(DISTINCT tdg_efl.group_name, '; ')
	            ELSE STRING_AGG(DISTINCT tdg_reqh.group_name, '; ')
	        END AS dimension_group_name,
	
	        CASE
	            WHEN MAX(CASE WHEN ttr_efl.timerequirementno_i IS NOT NULL THEN 1 ELSE 0 END) = 1
	            THEN 'YES'
	            ELSE 'NO'
	        END AS is_customized_effectivity,
	
	        MIN(tb_efl.intervalno_i) AS EFL_INTERVALNO_I,
	        MIN(tb_reqh.intervalno_i) AS REQH_INTERVALNO_I,
	        MIN(tb_efl.based_on) AS EFL_BASED_ON,
	        MIN(tb_reqh.based_on) AS REQH_BASED_ON,
	
	        STRING_AGG(DISTINCT dh_efl.doc_type, '; ') AS EFL_DOC_TYPE,
	        STRING_AGG(DISTINCT dh_reqh.doc_type, '; ') AS REQH_DOC_TYPE,
	        STRING_AGG(DISTINCT dh_efl.docno, '; ') AS EFL_DOCNO,
	        STRING_AGG(DISTINCT dh_reqh.docno, '; ') AS REQH_DOCNO,

		MIN(tdg_efl.next_due_rule_id) AS EFL_NEXT_DUE_RULE_ID,
		MIN(tdg_reqh.next_due_rule_id) AS REQH_NEXT_DUE_RULE_ID,
		MIN(tcm_predef.predefined_model) AS PREDEFINED_MODEL,

		MIN(tig_efl.status) AS EFL_STATUS,
		MIN(tig_reqh.status) AS REQH_STATUS,
	
	        MIN(CASE WHEN ti_efl.dimension_type = 'W' AND ti_efl.counter_defno_i = 1 THEN ti_efl.amount_interval END) AS EFL_THR_CYC,
	        MIN(CASE WHEN ti_efl.dimension_type = 'W' AND ti_efl.counter_defno_i = 2 THEN ti_efl.amount_interval END) AS EFL_THR_HRS,
	        MIN(CASE WHEN ti_efl.dimension_type = 'W' AND ti_efl.counter_defno_i = 3 THEN ti_efl.amount_interval END) AS EFL_THR_DAY,
	        MIN(CASE WHEN ti_efl.dimension_type = 'W' AND ti_efl.counter_defno_i = 3 THEN ti_efl.unit END) AS EFL_THR_UNIT,
	
	        MIN(CASE WHEN ti_efl.dimension_type = 'I' AND ti_efl.counter_defno_i = 1 THEN ti_efl.amount_interval END) AS EFL_INT_CYC,
	        MIN(CASE WHEN ti_efl.dimension_type = 'I' AND ti_efl.counter_defno_i = 2 THEN ti_efl.amount_interval END) AS EFL_INT_HRS,
	        MIN(CASE WHEN ti_efl.dimension_type = 'I' AND ti_efl.counter_defno_i = 3 THEN ti_efl.amount_interval END) AS EFL_INT_DAY,
	        MIN(CASE WHEN ti_efl.dimension_type = 'I' AND ti_efl.counter_defno_i = 3 THEN ti_efl.unit END) AS EFL_INT_UNIT,
	
	        MIN(CASE WHEN ti_reqh.dimension_type = 'W' AND ti_reqh.counter_defno_i = 1 THEN ti_reqh.amount_interval END) AS REQH_THR_CYC,
	        MIN(CASE WHEN ti_reqh.dimension_type = 'W' AND ti_reqh.counter_defno_i = 2 THEN ti_reqh.amount_interval END) AS REQH_THR_HRS,
	        MIN(CASE WHEN ti_reqh.dimension_type = 'W' AND ti_reqh.counter_defno_i = 3 THEN ti_reqh.amount_interval END) AS REQH_THR_DAY,
	        MIN(CASE WHEN ti_reqh.dimension_type = 'W' AND ti_reqh.counter_defno_i = 3 THEN ti_reqh.unit END) AS REQH_THR_UNIT,
	
	        MIN(CASE WHEN ti_reqh.dimension_type = 'I' AND ti_reqh.counter_defno_i = 1 THEN ti_reqh.amount_interval END) AS REQH_INT_CYC,
	        MIN(CASE WHEN ti_reqh.dimension_type = 'I' AND ti_reqh.counter_defno_i = 2 THEN ti_reqh.amount_interval END) AS REQH_INT_HRS,
	        MIN(CASE WHEN ti_reqh.dimension_type = 'I' AND ti_reqh.counter_defno_i = 3 THEN ti_reqh.amount_interval END) AS REQH_INT_DAY,
	        MIN(CASE WHEN ti_reqh.dimension_type = 'I' AND ti_reqh.counter_defno_i = 3 THEN ti_reqh.unit END) AS REQH_INT_UNIT
	
	    FROM msc_mp_issue mmi
	    JOIN msc_mp_revision mmr
	        ON mmi.issueno_i = mmr.issueno_i
	
	    JOIN msc_mprev_taskcards mmt
	        ON mmr.revisionno_i = mmt.revisionno_i
	
	    JOIN msc_taskcard_version mtv
	        ON mmt.taskcard_verno_i = mtv.taskcard_verno_i

		LEFT JOIN db_link dbl_main
    	ON dbl_main.source_type = 'TCLS'
   		AND dbl_main.source_pk = mtv.taskcard_verno_i::text
	
	    JOIN msc_taskcard mt
	        ON mtv.taskcardno_i = mt.taskcardno_i
	
	    JOIN msc_maintenance_program mmp
	        ON mmi.mpno_i = mmp.mpno_i
	
	    LEFT JOIN msc_task_section mts
	        ON mtv.taskcard_verno_i = mts.taskcard_verno_i
	
	    LEFT JOIN msc_section_code msc_sec
	        ON mts.sectionno_i = msc_sec.sectionno_i

		LEFT JOIN msc_task_type mtt
    		ON mtv.taskcard_verno_i = mtt.taskcard_verno_i

		LEFT JOIN msc_type_code mtc
    		ON mtt.typecodeno_i = mtc.typecodeno_i

		LEFT JOIN msc_task_msg mtm
    		ON mtv.taskcard_verno_i = mtm.taskcard_verno_i

		LEFT JOIN msc_msg_code mmc
    		ON mtm.msgno_i = mmc.msgno_i

		LEFT JOIN msc_requirement_zone mrz
    		ON mtv.taskcard_verno_i = mrz.taskcard_verno_i
	
	    LEFT JOIN msc_task_special mtsp
	        ON mtv.taskcard_verno_i = mtsp.taskcard_verno_i
	
	    JOIN msc_item mi
	        ON mtv.taskcard_verno_i = mi.taskcard_verno_i
	
	    LEFT JOIN event_effectivity_link eel
	        ON mi.itemno_i = eel.event_key
	       AND eel.event_type = 'TI'
	
	    LEFT JOIN event_effectivity ee
	        ON eel.effectivityno_i = ee.effectivityno_i

		LEFT JOIN applicability appl
    		ON ee.effectivityno_i = appl.effectivityno_i
   			AND appl.group_type = 'MMP'
   			AND appl.applicable = 'Y'
			AND appl.planable = 'Y'

		LEFT JOIN aircraft ac_appl
    		ON appl.ref_key = ac_appl.aircraftno_i
	
	    LEFT JOIN event_effectivity_rules eer
	        ON eel.effectivityno_i = eer.effectivityno_i
	
	    LEFT JOIN address adr
	        ON eer.aircraft_operator = adr.address_i
	
	    LEFT JOIN ac_mission_configuration amc
	        ON eer.aircraft_mission_config = amc.ac_configurationno_i
	
	    LEFT JOIN requirement_header rh
	        ON rh.event_type = 'TI'
	       AND rh.event_key = mi.itemno_i
	
	    LEFT JOIN worktemplate_link wtl_efl
	        ON wtl_efl.event_type = 'EFL'
	       AND wtl_efl.event_key = eel.effectivity_linkno_i
	
	    LEFT JOIN event_template et_efl
	        ON wtl_efl.wtno_i = et_efl.wtno_i

		LEFT JOIN workstep_link wsl_efl
	        ON et_efl.event_perfno_i = wsl_efl.event_perfno_i

		LEFT JOIN zone_code_link zcl_efl
    		ON zcl_efl.source_type = 'WS'
   			AND zcl_efl.source_pk = wsl_efl.descno_i
	   
	    LEFT JOIN wo_text_description wtd_efl
	        ON wsl_efl.descno_i = wtd_efl.descno_i
	
	    LEFT JOIN worktemplate_link wtl_reqh
	        ON wtl_reqh.event_type = 'REQH'
	       AND wtl_reqh.event_key = rh.requirement_headerno_i
	       AND NOT EXISTS (
	            SELECT 1
	            FROM worktemplate_link wtl_chk
	            WHERE wtl_chk.event_type = 'EFL'
	              AND wtl_chk.event_key = eel.effectivity_linkno_i
	       )
	
	    LEFT JOIN event_template et_reqh
	        ON wtl_reqh.wtno_i = et_reqh.wtno_i
	
	    LEFT JOIN workstep_link wsl_reqh
	        ON et_reqh.event_perfno_i = wsl_reqh.event_perfno_i
	
	    LEFT JOIN wo_text_description wtd_reqh
	        ON wsl_reqh.descno_i = wtd_reqh.descno_i
	
	    LEFT JOIN special_code_link scl
	        ON scl.source_pk = COALESCE(wsl_efl.descno_i, wsl_reqh.descno_i)
	
	    LEFT JOIN treq_time_requirement ttr_efl
	        ON ttr_efl.event_type = 'EFL'
	       AND ttr_efl.event_key = eel.effectivity_linkno_i
	
	    LEFT JOIN treq_interval_group tig_efl
	        ON ttr_efl.timerequirementno_i = tig_efl.timerequirementno_i
	
	    LEFT JOIN treq_dimension_group tdg_efl
	        ON tig_efl.interval_groupno_i = tdg_efl.interval_groupno_i
	
	    LEFT JOIN treq_interval ti_efl
	        ON tdg_efl.dimension_groupno_i = ti_efl.dimension_groupno_i
	
	    LEFT JOIN treq_baseline tb_efl
	        ON ti_efl.intervalno_i = tb_efl.intervalno_i
	
	    LEFT JOIN treq_baseline_threshold tbt_efl
	        ON tb_efl.baselineno_i = tbt_efl.baselineno_i
	       AND tbt_efl.event_type = 'DO'
	
	    LEFT JOIN doc_header dh_efl
	        ON tbt_efl.event_key = dh_efl.docno_i
	
	    LEFT JOIN treq_time_requirement ttr_reqh
	        ON ttr_reqh.event_type = 'REQH'
	       AND ttr_reqh.event_key = rh.requirement_headerno_i
	
	    LEFT JOIN treq_interval_group tig_reqh
	        ON ttr_reqh.timerequirementno_i = tig_reqh.timerequirementno_i

		LEFT JOIN treq_calculation_model tcm_predef
			ON tcm_predef.treq_calc_modelno_i = -3
	
	    LEFT JOIN treq_dimension_group tdg_reqh
	        ON tig_reqh.interval_groupno_i = tdg_reqh.interval_groupno_i
	
	    LEFT JOIN treq_interval ti_reqh
	        ON tdg_reqh.dimension_groupno_i = ti_reqh.dimension_groupno_i
	
	    LEFT JOIN treq_baseline tb_reqh
	        ON ti_reqh.intervalno_i = tb_reqh.intervalno_i
	
	    LEFT JOIN treq_baseline_threshold tbt_reqh
	        ON tb_reqh.baselineno_i = tbt_reqh.baselineno_i
	       AND tbt_reqh.event_type = 'DO'
	
	    LEFT JOIN doc_header dh_reqh
	        ON tbt_reqh.event_key = dh_reqh.docno_i
	
	    WHERE mmi.mpno_i = 206
	      AND mmi.issueno_i = 301
	      AND mmr.revision_no = '17'
	
	    GROUP BY
	        mmp.mpno,
	        mmi.issue_no,
	        mmr.revision_no,
	        mt.taskcardno,
	        mtv.single_running,
	        mt.taskcardno_i,
	        mtv.taskcard_verno_i,
	        mt.title,
	        CASE
	    WHEN wsl_efl.descno_i IS NOT NULL THEN wsl_efl.descno_i
	    ELSE wsl_reqh.descno_i
	END,
	
	CASE
	    WHEN wsl_efl.descno_i IS NOT NULL THEN wtd_efl.text
	    ELSE wtd_reqh.text
	END,
	        mtv.revision_date,
	        mtv.revision_no,
	        mtv.release_date,
	        mtv.revision_reason,
	        mtv.mrb_revision_number,
	        mtv.mrb_revision_date,
	        mtv.mrb_revision_reason,
	        mi.itemno_i,
	        eel.event_key,
	        eel.effectivityno_i,
